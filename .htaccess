Options -Indexes
Options -MultiViews

# ── Block direct access to all PHP files by default ──────────────────────────
<FilesMatch "\.php$">
  Order Deny,Allow
  Deny from all
</FilesMatch>

# ── Exceptions: files allowed from ALL hosts ─────────────────────────────────
<Files "index.php">
  Order Allow,Deny
  Allow from all
</Files>

<Files "pass_hash.php">
  Order Allow,Deny
  Allow from all
</Files>

<Files "reset.php">
  Order Allow,Deny
  Allow from all
</Files>

# ── Exception: midnight_reset.php — localhost only ────────────────────────────
<Files "midnight_reset.php">
  Order Deny,Allow
  Deny from all
  Allow from 127.0.0.1
  Allow from ::1
  Allow from localhost
</Files>

<Files "test_cron.php">
  Order Deny,Allow
  Deny from all
  Allow from 127.0.0.1
  Allow from ::1
  Allow from localhost
</Files>

# ── Rewrite: route everything through index.php ───────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /altaslive/

  # ── Serve frontend landing page at the root URL (no ?page= param) ────────────
  # Matches: /altaslive/  OR  /altaslive/index.php  (with no query string page param)
  # Internally forwards to frontend/index.php — URL stays http://localhost/altaslive/
  RewriteCond %{QUERY_STRING} (?:^|&)page= [NC]
  RewriteRule ^ - [S=1]
  RewriteRule ^(index\.php)?$ frontend/index.php [QSA,L]

  # Allow direct access to real files and directories (assets, uploads)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# ── Block direct access to sensitive directories (except midnight_reset.php) ──
<IfModule mod_rewrite.c>
  # Skip the block for midnight_reset.php so the <Files> allow above takes effect
  RewriteCond %{REQUEST_URI} !midnight_reset\.php$
  RewriteCond %{REQUEST_URI} !test_cron\.php$
  RewriteRule ^(config|core|models|controllers|cron|logs)/ - [F,L]
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
